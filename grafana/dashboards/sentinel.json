{
  "uid": "sentinel",
  "title": "Sentinel",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(prediction_requests_total[1m])",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "p99 Latency (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(prediction_latency_seconds_bucket[1m])) * 1000",
          "legendFormat": "p99 ms",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(prediction_errors_total[1m]) / rate(prediction_requests_total[1m]) * 100",
          "legendFormat": "error %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Canary Weight",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "(route_decisions_total{model=\"canary\"}) / (route_decisions_total{model=\"champion\"} + route_decisions_total{model=\"canary\"})",
          "legendFormat": "canary weight",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Data Drift PSI (max across features)",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "max(data_drift_psi)",
          "legendFormat": "max PSI",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 0.2}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Prediction Drift KL Divergence",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "prediction_drift_kl_divergence",
          "legendFormat": "KL divergence",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.05},
              {"color": "red", "value": 0.1}
            ]
          }
        }
      }
    }
  ]
}
